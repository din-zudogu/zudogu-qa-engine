# Base URL of the platform (main domain — admin signin)
BASE_URL=http://127.0.0.1:3000

# --- Platform admin (Din) — used by npm run auth:setup → storage/adminStorageState.json
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# --- Tenant store owner — signin on tenant host (subdomain)
# Example local: http://yourstore.localhost:3000
TENANT_BASE_URL=http://yourstore.localhost:3000
TENANT_EMAIL=merchant@example.com
TENANT_PASSWORD=

# Optional: run auth before every `npx playwright test` (slow)
# RUN_AUTH_BEFORE_TESTS=1

# Skip auth in global-setup / skip generating state in CI
# SKIP_GLOBAL_AUTH=1

# Optional: show browser during auth:setup
# HEADED=1
