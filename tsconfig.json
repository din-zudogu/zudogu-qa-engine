{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": [
    "playwright.config.ts",
    "global-setup.ts",
    "tests/**/*.ts",
    "utils/**/*.ts",
    "scripts/**/*.ts"
  ]
}
